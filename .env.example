# API (backend)
NEXT_PUBLIC_API_BASE_URL=https://dev-api.pulsepairs.com

# Chain ID drives the active viem/wagmi chain object + the Alchemy URL
# subdomain via src/config/environment.ts. Supported: 42161 (Arbitrum One),
# 421614 (Arbitrum Sepolia). Defaults to 42161.
NEXT_PUBLIC_CHAIN_ID=42161

# Optional: Alchemy. If unset, app falls back to the public RPC for the
# active chain. Same key works across Arbitrum One + Arbitrum Sepolia.
NEXT_PUBLIC_ALCHEMY_API_KEY=

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
