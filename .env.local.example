# Copy to .env.local — no secrets in git for production keys.

# Required for Alchemy RPC transport (same key for Arbitrum One + Sepolia).
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Backend (REST + WS derived from same host in src/lib/env.ts)
NEXT_PUBLIC_API_BASE_URL=https://dev-api.pulsepairs.com

# 42161 (Arbitrum One) or 421614 (Arbitrum Sepolia). Drives chain object
# selection in src/config/environment.ts. Defaults to 42161.
NEXT_PUBLIC_CHAIN_ID=42161

# Optional
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
